import java.io.*;
class Main {
	public static void main(String[] args) throws Exception {
		BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
		String input = br.readLine();

		int[] arr = new int[4];

		for (char c : input.toCharArray()) {
			switch (c) {
				case '1' : arr[0]++;
					break;
				case 'I' : arr[1]++;
					break;
				case 'l' : arr[2]++;
					break;
				case '|' : arr[3]++;
					break;
			}
		}

		for (int n : arr) {
			System.out.println(n);
		}
	}
}